<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="20.0%p"
    android:horizontalGap="1.0px"
    android:verticalGap="1.0px"
    android:keyHeight="@dimen/key_height">

     <Row>
        <Key android:codes="@integer/jp_key_turn" android:keyEdgeFlags="left" android:keyIcon="@drawable/key_jp_return" 
            android:iconPreview="@drawable/key_jp_return" android:isModifier="true"/>
        <Key android:codes="906" android:keyIcon="@drawable/key_jp_d_1" 
            android:iconPreview="@drawable/key_jp_d_1_zoom"/>
        <Key android:codes="907" android:keyIcon="@drawable/key_jp_d_2"
            android:iconPreview="@drawable/key_jp_d_2_zoom"/>
        <Key android:codes="908" android:keyIcon="@drawable/key_jp_d_3"
            android:iconPreview="@drawable/key_jp_d_3_zoom"/>
        <Key android:codes="@integer/key_back" android:keyEdgeFlags="right" android:isRepeatable="true" 
            android:keyIcon="@drawable/key_delete_n"
            android:isModifier="true"/>
    </Row>
    <Row>
        <Key android:codes="@integer/key_blank" android:keyEdgeFlags="left" android:keyLabel=" "/>
        <Key android:codes="909" android:keyIcon="@drawable/key_jp_d_4" 
            android:iconPreview="@drawable/key_jp_d_4_zoom"/>
        <Key android:codes="910" android:keyIcon="@drawable/key_jp_d_5" 
            android:iconPreview="@drawable/key_jp_d_5_zoom"/>
        <Key android:codes="911" android:keyIcon="@drawable/key_jp_d_6" 
            android:iconPreview="@drawable/key_jp_d_6_zoom"/>
        <Key android:codes="@integer/key_blank" android:keyEdgeFlags="right" android:keyLabel=" "/>
    </Row>
    <Row>
        <Key android:codes="@integer/jp_key_global" android:keyEdgeFlags="left" android:keyIcon="@drawable/key_jp_caps_4" 
            android:iconPreview="@drawable/key_jp_caps_4" android:isModifier="true"/>
        <Key android:codes="902" android:keyIcon="@drawable/key_jp_d_7" 
            android:iconPreview="@drawable/key_jp_b_11_zoom"/>
        <Key android:codes="912" android:keyIcon="@drawable/key_jp_d_8" 
            android:iconPreview="@drawable/key_jp_d_8_zoom"/>
        <Key android:codes="913" android:keyIcon="@drawable/key_jp_d_9" 
            android:iconPreview="@drawable/key_jp_d_9_zoom"/>
        <Key android:codes="203" android:keyEdgeFlags="right" android:keyIcon="@drawable/key_spacebar_2_n" 
            android:iconPreview="@drawable/key_spacebar_2_n" android:isModifier="true"/>
    </Row>
    <Row>
        <Key android:codes="@integer/key_hide" android:keyEdgeFlags="left" android:keyIcon="@drawable/key_keyboard_close_n" 
            android:iconPreview="@drawable/key_keyboard_close_n" android:isModifier="true"/>
        <Key android:codes="914" android:keyIcon="@drawable/key_jp_d_10" 
            android:iconPreview="@drawable/key_jp_d_10_zoom"/>
        <Key android:codes="915" android:keyIcon="@drawable/key_jp_d_11" 
            android:iconPreview="@drawable/key_jp_d_11_zoom"/>
        <Key android:codes="903" android:keyIcon="@drawable/key_jp_d_12" 
            android:iconPreview="@drawable/key_jp_b_12_zoom"/>
        <Key android:codes="@integer/key_enter" android:keyEdgeFlags="right" android:keyIcon="@drawable/key_enter_bg_n" 
            android:iconPreview="@drawable/key_enter_bg_n" android:isModifier="true"/>
    </Row>
    
</Keyboard>
    