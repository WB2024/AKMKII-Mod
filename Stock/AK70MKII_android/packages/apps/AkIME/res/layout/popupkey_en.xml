<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/candidate_popup_bg"
    android:orientation="vertical" >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal" >

        <LinearLayout
            android:id="@+id/popupkeyboard_top"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/en_popup_height"
            android:layout_weight="1"
            android:orientation="horizontal" >
        </LinearLayout>

        <ImageButton
            android:id="@+id/popupkeyboard_close"
            style="@style/android:Widget.Material.ActionButton"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:src="@drawable/btn_close_3" />
    </LinearLayout>
	
    <View 
        android:id="@+id/popupkeyboard_centerline"
        android:layout_width="match_parent"
        android:layout_height="@dimen/candidate_under_line_height"
        android:background="@color/candidate_popup_under_line"
        android:visibility="gone"/>
    
    <LinearLayout
        android:id="@+id/popupkeyboard_bottom"
        android:layout_width="match_parent"
        android:layout_height="@dimen/en_popup_height"
        android:orientation="horizontal" >
    </LinearLayout>

</LinearLayout>