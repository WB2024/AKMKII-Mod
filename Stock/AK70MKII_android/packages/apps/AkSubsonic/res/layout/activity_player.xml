<?xml version="1.0" encoding="utf-8"?>
<!-- Player Activity — Now Playing screen -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="@dimen/screen_padding">

    <!-- Album cover art (square, centered) -->
    <ImageView
        android:id="@+id/iv_cover_art"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:scaleType="centerCrop"
        android:background="@color/bg_card" />

    <!-- Track title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_title_medium"
        android:textStyle="bold"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:paddingBottom="4dp" />

    <!-- Artist name -->
    <TextView
        android:id="@+id/tv_artist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/accent"
        android:textSize="@dimen/text_body"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingBottom="2dp" />

    <!-- Album name -->
    <TextView
        android:id="@+id/tv_album"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_small"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingBottom="16dp" />

    <!-- Seek bar row -->
    <SeekBar
        android:id="@+id/seek_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

    <!-- Elapsed / Duration labels -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="2dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tv_elapsed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="0:00"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_small" />

        <TextView
            android:id="@+id/tv_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="0:00"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_small" />

    </RelativeLayout>

    <!-- Playback controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageButton
            android:id="@+id/btn_previous"
            android:layout_width="@dimen/control_btn_size"
            android:layout_height="@dimen/control_btn_size"
            android:src="@android:drawable/ic_media_previous"
            android:background="@drawable/bg_button"
            android:scaleType="fitCenter"
            android:padding="12dp"
            android:contentDescription="@string/action_previous" />

        <ImageButton
            android:id="@+id/btn_play_pause"
            android:layout_width="@dimen/control_btn_large"
            android:layout_height="@dimen/control_btn_large"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:src="@android:drawable/ic_media_play"
            android:background="@drawable/bg_button_accent"
            android:scaleType="fitCenter"
            android:padding="14dp"
            android:contentDescription="@string/action_play" />

        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="@dimen/control_btn_size"
            android:layout_height="@dimen/control_btn_size"
            android:src="@android:drawable/ic_media_next"
            android:background="@drawable/bg_button"
            android:scaleType="fitCenter"
            android:padding="12dp"
            android:contentDescription="@string/action_next" />

    </LinearLayout>

</LinearLayout>
